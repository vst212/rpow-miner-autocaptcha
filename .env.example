# YesCaptcha API key — used to solve Cloudflare Turnstile during login
# Get yours at https://yescaptcha.com
YESCAPTCHA_KEY=your_api_key_here

# RPOW server to mine on (optional, defaults to rpow2.com)
# Uncomment and change to switch servers, e.g. rpow3.com
# RPOW_SITE=https://rpow2.com
# RPOW_API=https://api.rpow2.com

# Cloudflare Turnstile site key for the target server (optional)
# Only needed if mining on a non-default server with a different site key
# RPOW_TURNSTILE_KEY=0x4AAAAAADLyZ9ztTUV1Pm1F
